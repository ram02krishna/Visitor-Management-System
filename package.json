  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc && vite build",
    "clean": "rimraf dist build .cache",
    "dev": "vite",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
