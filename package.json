{
  "name": "visitor-management-system",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@10.0.0",
  "scripts": {
    "build": "tsc && vite build",
    "clean": "rimraf dist build .cache",
    "dev": "vite",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "security:audit": "npm audit --production",
    "security:audit:fix": "npm audit fix --production",
    "security:check": "npm audit --json > audit-report.json && npm run security:audit",
    "security:update": "npm update && npm audit fix",
    "validate": "npm run type-check && npm run lint && npm run format:check && npm run security:audit",
    "validate:fix": "npm run lint:fix && npm run format && npm run security:audit:fix"
  },
  "dependencies": {
    "@emailjs/browser": "^4.4.1",
    "@eslint/js": "9.39.2",
    "@supabase/supabase-js": "^2.49.4",
    "@types/loglevel": "^1.5.4",
    "@types/papaparse": "^5.3.16",
    "date-fns": "^3.3.1",
    "html5-qrcode": "^2.3.8",
    "loglevel": "^1.9.2",
    "lucide-react": "^0.344.0",
    "papaparse": "^5.5.3",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^3.0.0",
    "react-hook-form": "^7.51.0",
    "react-hot-toast": "^2.4.1",
    "react-router-dom": "^7.0.0",
    "uuid": "^11.1.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.7",
    "@types/node": "25.0.3",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.2.56",
    "@types/react-dom": "^18.2.19",
    "@typescript-eslint/eslint-plugin": "^8.51.0",
    "@typescript-eslint/parser": "^8.51.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.18",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.5",
    "postcss": "^8.4.35",
    "prettier": "^3.6.2",
    "rimraf": "^6.1.2",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.51.0",
    "vite": "^7.3.0",
    "vite-plugin-mkcert": "^1.17.8",
    "vite-plugin-pwa": "^1.1.0"
  }
}
