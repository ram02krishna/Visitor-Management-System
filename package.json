    "date-fns": "^3.3.1",
    "lucide-react": "^0.344.0",
    "papaparse": "^5.5.3",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.51.0",
    "react-hot-toast": "^2.4.1",
    "react-qr-code": "^2.0.15",
    "react-router-dom": "^6.22.3",
    "tailwind-merge": "^2.2.1",
    "uuid": "^11.1.0",
    "zod": "^3.22.4",
    "zustand": "^4.5.2"
